{
  "name": "agentsla",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:contract": "node scripts/deploy.mjs",
    "lint": "node scripts/validate.mjs",
    "lint:json": "node scripts/validate.mjs --json",
    "validate": "node scripts/validate.mjs",
    "test": "sh -c '[ -x .venv/bin/python ] || npm run test:setup; .venv/bin/python -m pytest tests/direct/ -v'",
    "test:setup": "python3 -m venv .venv && .venv/bin/pip install -q -r requirements-dev.txt",
    "test:direct": ".venv/bin/python -m pytest tests/direct/ -v",
    "test:e2e": "node scripts/smoke.mjs",
    "check": "npm run validate && npm run test && npm run build"
  },
  "dependencies": {
    "@privy-io/react-auth": "^3.33.1",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "genlayer-js": "^1.1.8",
    "gsap": "^3.12.5",
    "lenis": "^1.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
